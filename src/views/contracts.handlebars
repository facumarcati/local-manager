<h1>
  {{#if (eq view "active")}}Contratos activos{{/if}}
  {{#if (eq view "history")}}Historial de contratos{{/if}}
</h1>

<div style="margin-bottom: 15px;">
  <a href="/contracts" style="{{#if (eq view 'active')}}font-weight:bold;{{/if}}">
    Activos
  </a> |
  <a href="/contracts/history" style="{{#if (eq view 'history')}}font-weight:bold;{{/if}}">
    Historial
  </a>
</div>

<a href="/contracts/new">
  Crear contrato
</a>

<hr />

<table border="1" cellpadding="5">
  <thead>
    <tr>
      <th>Local</th>
      <th>Inquilino</th>
      <th>Monto</th>
      <th>Inicio</th>
      <th>Fin</th>
      <th>Estado</th>
      <th>Acciones</th>
    </tr>
  </thead>

  <tbody>
    {{#if contracts.length}}
      {{#each contracts}}
        <tr>
          <td>{{this.local.name}}</td>
          <td>{{this.tenantName}}</td>
          <td>${{this.rentAmount}}</td>
          <td>{{formatDate this.startDate}}</td>
          <td>{{formatDate this.endDate}}</td>
          <td>
            {{#if (eq this.status "active")}}
              <span class="badge badge--green">Activo</span>
            {{else}}
              <span class="badge badge--gray">Finalizado</span>
            {{/if}}
          </td>
          <td>
            <a href="/contracts/edit/{{this._id}}">
              editar
            </a>

            {{#if (eq ../view "active")}}
              <form
                action="/contracts/finish/{{this._id}}"
                method="POST"
                style="display:inline;"
              >
                <button>
                  Finalizar
                </button>
              </form>
            {{/if}}
          </td>
        </tr>
      {{/each}}
    {{else}}
      <tr>
        <td colspan="7">
          No hay contratos cargados
        </td>
      </tr>
    {{/if}}
  </tbody>
</table>