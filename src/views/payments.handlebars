<div class="page-header">
  <div>
    <h1 class="page-title">
      {{#if (eq view "active")}}
        Pagos a cobrar
      {{else if (eq view "upcoming")}}
        Pagos futuros
      {{else if (eq view "history")}}
        Historial de pagos
      {{/if}}
    </h1>
  </div>
</div>

<div class="tab-nav">
  <a href="/payments" class="tab-item {{#if (eq view 'active')}}tab-item--active{{/if}}">
    Activos
  </a>
  <a href="/payments/upcoming" class="tab-item {{#if (eq view 'upcoming')}}tab-item--active{{/if}}">
    Próximos
  </a>
  <a href="/payments/history" class="tab-item {{#if (eq view 'history')}}tab-item--active{{/if}}">
    Historial
  </a>
</div>

<table border="1" cellpadding="5">
  <thead>
    <tr>
      <th>Local</th>
      <th>Inquilino</th>
      <th>Período</th>

      {{#if (eq view "history")}}
        <th>Vencimiento</th>
        <th>Monto pagado</th>
        <th>Fecha</th>
        <th>Detalle</th>
      {{else}}
        <th>Monto</th>
        <th>Vencimiento</th>
        <th>Estado</th>
        <th>Pagado</th>
        <th>Restante</th>
        <th>Acciones</th>
      {{/if}}
    </tr>
  </thead>

  <tbody>
    {{#if payments.length}}

      {{#if (eq view "history")}}
        {{#each payments}}
          <tr>
            <td>{{this.payment.local.name}}</td>
            <td>{{this.payment.contract.tenantName}}</td>
            <td>{{this.payment.period}}</td>
            <td>
              {{formatDate this.payment.dueDate}}
            </td>
            <td class="amount-ok">
              ${{this.amount}}
            </td>
            <td>{{formatDate this.date}}</td>
            <td>
              <small>de ${{this.payment.amount}}</small>
            </td>
          </tr>
        {{/each}}
      {{else}}
        {{#each payments}}
          <tr>
            <td>{{this.local.name}}</td>
            <td>{{this.contract.tenantName}}</td>
            <td>{{this.period}}</td>
            <td>${{this.amount}}</td>
            <td>{{formatDate this.dueDate}}</td>
            <td>
              {{#if (eq this.status "paid")}}
                <span class="badge badge--green">Pagado</span>
              {{else if (eq this.status "partial")}}
                <span class="badge badge--yellow">Parcial</span>
              {{else if (isLate this.dueDate)}}
                <span class="badge badge--red">Vencido</span>
              {{else}}
                <span class="badge badge--gray">Pendiente</span>
              {{/if}}
            </td>
            <td>${{this.paidAmount}}</td>
            <td>
              ${{subtract this.amount this.paidAmount}}
            </td>
            <td>
              {{#if (eq this.status "paid")}}
                <span class="badge badge--green">Completo</span>
              {{else}}
                <form
                  action="/payments/pay/{{this._id}}?view={{../view}}"
                  method="POST"
                  style="display:flex; gap:6px;"
                >
                  <input 
                    type="number" 
                    name="amount" 
                    placeholder="Monto"
                    min="1"
                    max="{{subtract this.amount this.paidAmount}}"
                    style="width:90px;"
                    required
                  />
                  <button type="submit" class="btn btn--sm btn--primary">
                    Pagar
                  </button>
                </form>
              {{/if}}
            </td>
          </tr>
        {{/each}}
      {{/if}}
    {{else}}
      <tr>
        <td colspan="10" style="text-align:center;">
          No hay pagos cargados
        </td>
      </tr>
    {{/if}}
  </tbody>
</table>